generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// CORE MODELS
// ═══════════════════════════════════════════════════════════════════════════

model Warehouse {
  id                String             @id @default(cuid())
  name              String             @unique
  code              String?            @unique
  address           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  productions       Production[]
  receipts          Receipt[]
  sttbs             STTB[]
  stocks            Stock[]
  batches           StockBatch[]

  // Cattle relations
  cattlePurchasings  CattlePurchasing[]
  cattleArrivals     CattleArrival[]
  cattleBatches      CattleBatch[]
  cattleInventory    CattleInventory[]
}

model User {
  id        String          @id @default(cuid())
  username  String          @unique
  email     String          @unique
  password  String
  phone     String?
  role      String          @default("Staff")
  createdAt DateTime        @default(now())
  roleData  RolePermission? @relation("UserToRole", fields: [role], references: [roleName])
  staffs    staffs?
}

model RolePermission {
  id          String   @id @default(cuid())
  roleName    String   @unique
  permissions String[]
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("UserToRole")
}

// ═══════════════════════════════════════════════════════════════════════════
// DELIVERY ORDER (BARANG UMUM)
// ═══════════════════════════════════════════════════════════════════════════

model DeliveryOrder {
  id           String              @id @default(cuid())
  doNo         String              @unique
  expectedDate DateTime?
  notes        String?             @default("")
  requestedBy  String
  status       String              @default("PENDING")
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  title        String?
  items        DeliveryOrderItem[]
}

model DeliveryOrderItem {
  id               String        @id @default(cuid())
  deliveryOrderId  String
  unit             String        @default("Kg")
  estimasiHarga    Float         @default(0)
  notes            String?       @default("")
  createdAt        DateTime      @default(now())
  qtyRequired      Float         @default(0)
  category         String        @default("")
  type             String        @default("STOCKS")
  qtyOrdered       Float         @default(0)
  itemName         String
  updatedAt        DateTime      @updatedAt
  deliveryOrder    DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  purchasingOrders Purchasing[]
}

// ═══════════════════════════════════════════════════════════════════════════
// PURCHASING (BARANG UMUM)
// ═══════════════════════════════════════════════════════════════════════════

model Purchasing {
  id                  String             @id @default(cuid())
  noPO                String
  item                String
  category            String
  type                String             @default("STOCKS")
  supplier            String?
  status              PurchaseStatus     @default(PENDING)
  isReceived          Boolean            @default(false)
  requestedBy         String
  approvedBy          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  price               String?
  unit                String             @default("KG")
  qty                 Float              @default(0)
  notes               String?
  deliveryOrderItemId String?
  deliveryOrderItem   DeliveryOrderItem? @relation(fields: [deliveryOrderItemId], references: [id])
  receipts            Receipt[]
  sttb                STTB?
  batches             StockBatch[]
}

model Receipt {
  id           String     @id @default(cuid())
  receiptNo    String     @unique
  purchasingId String
  suratJalan   String
  vehicleNo    String
  receivedQty  Float
  receivedBy   String
  condition    String     @default("GOOD")
  notes        String?
  receivedAt   DateTime   @default(now())
  grossWeight  Float      @default(0)
  netWeight    Float      @default(0)
  tareWeight   Float      @default(0)
  imageUrl     String?
  warehouseId  String?
  refraksi     Float      @default(0)
  purchasing   Purchasing @relation(fields: [purchasingId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  sttb         STTB?
  batch        StockBatch?
}

// ─── STTB (diperbarui: mendukung barang umum DAN sapi) ─────────────────────
//
// Perubahan dari versi sebelumnya:
//   - receiptId dan purchasingId dibuat OPSIONAL (nullable) agar STTB sapi
//     bisa dibuat tanpa Receipt/Purchasing barang
//   - Tambah field isCattle, cattlePOId, dan data timbang sapi
//   - Tambah relasi ke CattlePurchasing

model STTB {
  id                   String            @id @default(cuid())
  sttbNo               String            @unique
  status               String            @default("PENDING_QC")

  // ── Barang umum (nullable saat isCattle = true) ──────────────────────────
  receiptId            String?           @unique
  purchasingId         String?           @unique
  receipt              Receipt?          @relation(fields: [receiptId], references: [id])
  purchasing           Purchasing?       @relation(fields: [purchasingId], references: [id])

  // ── Cattle mode ──────────────────────────────────────────────────────────
  isCattle             Boolean           @default(false)
  cattlePOId           String?
  cattleArrivalId      String?
  cattlePO             CattlePurchasing? @relation("CattlePOSTTB", fields: [cattlePOId], references: [id])

  // Data timbang sapi (nullable untuk STTB barang)
  jumlahEkor           Int?
  beratHidupTotal      Float?            // Total berat hidup tiba (kg)
  beratHidupRata       Float?            // Rata-rata berat per ekor (kg)
  beratBeli            Float?            // Berat rata-rata saat beli dari PO (kg/ekor)
  susutKg              Float?            // beratBeli - beratHidupRata
  susutPct             Float?            // (susutKg / beratBeli) × 100
  susutAlert           Boolean           @default(false) // true jika susut > 8.5%

  // ── Approval stamps ───────────────────────────────────────────────────────
  qcApprovedBy         String?
  qcApprovedAt         DateTime?
  qcNotes              String?
  adminApprovedBy      String?
  adminApprovedAt      DateTime?
  adminNotes           String?
  supervisorApprovedBy String?
  supervisorApprovedAt DateTime?
  supervisorNotes      String?
  managerApprovedBy    String?
  managerApprovedAt    DateTime?
  managerNotes         String?

  // ── Reject ────────────────────────────────────────────────────────────────
  rejectedBy           String?
  rejectedAt           DateTime?
  rejectedNotes        String?

  // ── Gudang ───────────────────────────────────────────────────────────────
  warehouseId          String?
  warehouse            Warehouse?        @relation(fields: [warehouseId], references: [id])
  stockCommitted       Boolean           @default(false)
  stockCommittedAt     DateTime?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  batch                StockBatch?

  @@index([isCattle])
  @@index([cattlePOId])
  @@index([status])
}

model Stock {
  id              String    @id @default(cuid())
  name            String
  category        String
  stock           Float
  unit            String
  type            String
  price           String?
  status          String?
  lastPurchasedId String?
  updatedAt       DateTime  @updatedAt
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([name, warehouseId])
}

model StockBatch {
  id                        String                      @id @default(cuid())
  batchNo                   String                      @unique
  itemName                  String
  warehouseId               String
  purchasingId              String?
  receiptId                 String?                     @unique
  sttbId                    String?                     @unique
  supplierName              String?
  noPO                      String?
  suratJalan                String?
  qtyInitial                Float
  qtyRemaining              Float
  reservedQty               Float                       @default(0)
  unit                      String                      @default("KG")
  category                  String                      @default("General")
  type                      String                      @default("STOCKS")
  price                     String?
  condition                 String?                     @default("GOOD")
  notes                     String?
  status                    String                      @default("ACTIVE")
  receivedAt                DateTime                    @default(now())
  depletedAt                DateTime?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  productionId              String?
  deductions                BatchDeduction[]
  allocations               ProductionBatchAllocation[]
  production                Production?                 @relation("ProductionOutputBatch", fields: [productionId], references: [id])
  purchasing                Purchasing?                 @relation(fields: [purchasingId], references: [id])
  receipt                   Receipt?                    @relation(fields: [receiptId], references: [id])
  sttb                      STTB?                       @relation(fields: [sttbId], references: [id])
  warehouse                 Warehouse                   @relation(fields: [warehouseId], references: [id])

  @@index([itemName, warehouseId, status])
  @@index([receivedAt])
  @@index([status])
  @@index([reservedQty])
}

model BatchDeduction {
  id            String     @id @default(cuid())
  batchId       String
  referenceId   String?
  referenceType String?
  referenceNo   String?
  qtyDeducted   Float
  unit          String     @default("KG")
  deductedBy    String?
  notes         String?
  createdAt     DateTime   @default(now())
  batch         StockBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([referenceId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// PRODUCTION
// ═══════════════════════════════════════════════════════════════════════════

model Production {
  id                   String                @id @default(cuid())
  noBatch              String                @unique
  productName          String
  targetQty            Float
  actualQty            Float?
  status               ProductionStatus      @default(PENDING_QC_PROD)
  totalCost            Float                 @default(0)
  unitCost             Float                 @default(0)
  startDate            DateTime              @default(now())
  endDate              DateTime?
  createdBy            String
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  adminApprovedAt      DateTime?
  adminApprovedBy      String?
  adminNotes           String?
  hpp                  Float                 @default(0)
  lossWarning          Boolean               @default(false)
  managerApprovedAt    DateTime?
  managerApprovedBy    String?
  managerNotes         String?
  qcApprovedAt         DateTime?
  qcApprovedBy         String?
  qcNotes              String?
  rejectedAt           DateTime?
  rejectedBy           String?
  rejectedNotes        String?
  rendemen             Float?
  supervisorApprovedAt DateTime?
  supervisorApprovedBy String?
  supervisorNotes      String?
  targetUnit           String                @default("UNIT")
  warehouseId          String?
  isReserved           Boolean               @default(false)
  reservedAt           DateTime?
  reservedBy           String?
  warehouse            Warehouse?            @relation(fields: [warehouseId], references: [id])
  components           ProductionComponent[]
  outputBatches        StockBatch[]          @relation("ProductionOutputBatch")

  @@index([isReserved])
}

model ProductionComponent {
  id                        String                      @id @default(cuid())
  productionId              String
  itemName                  String
  qtyNeeded                 Float
  unit                      String                      @default("KG")
  createdAt                 DateTime                    @default(now())
  batchAllocation           String?                     @default("[]")
  stockAvailable            Float                       @default(0)
  totalPrice                Float                       @default(0)
  unitPrice                 Float                       @default(0)
  warehouseId               String?
  reservedQty               Float                       @default(0)
  allocations               ProductionBatchAllocation[]
  production                Production                  @relation(fields: [productionId], references: [id], onDelete: Cascade)
}

model ProductionBatchAllocation {
  id                    String              @id @default(cuid())
  productionComponentId String
  batchId               String
  qtyAllocated          Float               @default(0)
  isReserved            Boolean             @default(false)
  isDeducted            Boolean             @default(false)
  createdAt             DateTime            @default(now())
  batch                 StockBatch          @relation(fields: [batchId], references: [id], onUpdate: NoAction)
  productionComponent   ProductionComponent @relation(fields: [productionComponentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([batchId])
  @@index([productionComponentId])
  @@index([isReserved])
}

// ═══════════════════════════════════════════════════════════════════════════
// PENJUALAN (SALES)
// ═══════════════════════════════════════════════════════════════════════════

model Penjualan {
  id                   String          @id @default(cuid())
  invoiceId            String          @unique
  totalAmount          Float           @default(0)
  status               String          @default("PENDING_SALES")
  customerId           String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  createdBy            String?
  deliveryAddress      String?
  discount             Float           @default(0)
  discountPct          Float           @default(0)
  dueDate              DateTime?
  notes                String?
  paidAt               DateTime?
  paymentMethod        String?         @default("CASH")
  quotationId          String?
  salesNotes           String?
  shippingCost         Float           @default(0)
  subtotal             Float           @default(0)
  taxAmount            Float           @default(0)
  taxPct               Float           @default(0)
  saleType             String          @default("REGULAR")
  salesApprovedBy      String?
  salesApprovedAt      DateTime?
  salesNotes2          String?
  adminApprovedBy      String?
  adminApprovedAt      DateTime?
  adminNotes2          String?
  supervisorApprovedBy String?
  supervisorApprovedAt DateTime?
  supervisorNotes      String?
  managerApprovedBy    String?
  managerApprovedAt    DateTime?
  managerNotes         String?
  rejectedBy           String?
  rejectedAt           DateTime?
  rejectedNotes        String?
  isStockDeducted      Boolean         @default(false)
  customer             Contact?        @relation(fields: [customerId], references: [id])
  quotation            SalesQuotation? @relation("QuotationToSale", fields: [quotationId], references: [id])
  items                PenjualanItem[]

  @@index([saleType])
  @@index([status])
  @@index([isStockDeducted])
}

model PenjualanItem {
  id              String    @id @default(cuid())
  productName     String
  quantity        Float
  unit            String?   @default("Unit")
  price           Float
  penjualanId     String
  discount        Float     @default(0)
  notes           String?
  subtotal        Float     @default(0)
  batchAllocation String?   @default("[]")
  warehouseId     String?
  unitCost        Float     @default(0)
  totalCost       Float     @default(0)
  margin          Float     @default(0)
  penjualan       Penjualan @relation(fields: [penjualanId], references: [id], onDelete: Cascade)
}

model SalesQuotation {
  id          String               @id @default(cuid())
  quotationNo String               @unique
  customerId  String?
  status      String               @default("DRAFT")
  validUntil  DateTime?
  notes       String?
  subtotal    Float                @default(0)
  discountPct Float                @default(0)
  discount    Float                @default(0)
  taxPct      Float                @default(0)
  taxAmount   Float                @default(0)
  totalAmount Float                @default(0)
  createdBy   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  salesOrders Penjualan[]          @relation("QuotationToSale")
  customer    Contact?             @relation(fields: [customerId], references: [id])
  items       SalesQuotationItem[]
}

model SalesQuotationItem {
  id          String         @id @default(cuid())
  quotationId String
  productName String
  quantity    Float
  unit        String         @default("Unit")
  price       Float
  discount    Float          @default(0)
  subtotal    Float          @default(0)
  notes       String?
  quotation   SalesQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Contact {
  id          String           @id @default(cuid())
  name        String
  type        ContactType      @default(CUSTOMER)
  email       String?          @unique
  phone       String?
  address     String?
  createdAt   DateTime         @default(now())
  companyName String?
  nik         String?          @unique
  penjualan   Penjualan[]
  quotations  SalesQuotation[]
}

// ═══════════════════════════════════════════════════════════════════════════
// CATTLE MODULE (LIVESTOCK)
// ═══════════════════════════════════════════════════════════════════════════

// ─── Master Jenis Sapi ────────────────────────────────────────────────────────

model CattleBreed {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  createdAt   DateTime       @default(now())
  doItems     CattleDOItem[]
  poItems     CattlePOItem[]
}

// ─── Delivery Order Sapi ──────────────────────────────────────────────────────

model CattleDeliveryOrder {
  id            String          @id @default(cuid())
  doNo          String          @unique
  title         String?
  expectedDate  DateTime?
  notes         String?
  requestedBy   String
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectedNotes String?
  status        CattleDOStatus  @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         CattleDOItem[]

  @@index([status])
  @@index([createdAt])
}

// ─── DO Item Sapi ─────────────────────────────────────────────────────────────

model CattleDOItem {
  id                 String              @id @default(cuid())
  deliveryOrderId    String
  deliveryOrder      CattleDeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  breedId            String?
  breed              CattleBreed?        @relation(fields: [breedId], references: [id])
  jenisSapi          String
  gender             String              @default("CAMPUR")
  headRequired       Int                 @default(0)
  weightRequiredKg   Float               @default(0)
  headOrdered        Int                 @default(0)
  weightOrderedKg    Float               @default(0)
  estimasiHargaPerKg Float               @default(0)
  estimasiTotal      Float               @default(0)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  purchasingOrders   CattlePOItem[]

  @@index([deliveryOrderId])
}

// ─── Purchase Order Sapi ──────────────────────────────────────────────────────

model CattlePurchasing {
  id               String          @id @default(cuid())
  noPO             String
  vendorName       String
  vendorCountry    String          @default("Australia")
  vendorEksportir  String?
  totalHeadOrdered Int             @default(0)
  totalWeightKg    Float           @default(0)
  pricePerKgIDR    Float           @default(0)
  pricePerHeadUSD  Float           @default(0)
  exchangeRate     Float           @default(0)
  biayaBongkar     Float           @default(0)
  biayaTracking    Float           @default(0)
  biayaKarantina   Float           @default(0)
  biayaLainLain    Float           @default(0)
  hppPerKg         Float           @default(0)
  hppPerEkor       Float           @default(0)
  hppTotal         Float           @default(0)
  totalEstimasi    Float           @default(0)
  requestedBy      String
  approvedBy       String?
  approvedAt       DateTime?
  notes            String?
  status           CattlePOStatus  @default(DRAFT)
  isReceived       Boolean         @default(false)
  warehouseId      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  warehouse  Warehouse?       @relation(fields: [warehouseId], references: [id])
  items      CattlePOItem[]
  arrivals   CattleArrival[]  @relation("POArrivals")
  batches    CattleBatch[]
  sttbs      STTB[]           @relation("CattlePOSTTB")

  @@index([status])
  @@index([isReceived])
  @@index([createdAt])
}

// ─── PO Item Sapi ─────────────────────────────────────────────────────────────

model CattlePOItem {
  id              String           @id @default(cuid())
  purchasingId    String
  purchasing      CattlePurchasing @relation(fields: [purchasingId], references: [id], onDelete: Cascade)
  doItemId        String?
  doItem          CattleDOItem?    @relation(fields: [doItemId], references: [id])
  breedId         String?
  breed           CattleBreed?     @relation(fields: [breedId], references: [id])
  jenisSapi       String
  gender          String           @default("CAMPUR")
  headOrdered     Int              @default(0)
  weightKg        Float            @default(0)
  avgWeightKg     Float            @default(0)
  pricePerKg      Float            @default(0)
  totalHarga      Float            @default(0)
  pricePerHeadUSD Float            @default(0)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([purchasingId])
  @@index([doItemId])
}

// ─── Cattle Arrival (Penerimaan Sapi) ────────────────────────────────────────

model CattleArrival {
  id                 String           @id @default(cuid())
  arrivalNo          String           @unique
  purchasingId       String
  purchasing         CattlePurchasing @relation("POArrivals", fields: [purchasingId], references: [id])

  warehouseId        String?
  warehouse          Warehouse?       @relation(fields: [warehouseId], references: [id])

  // Logistik
  namaKapal          String?
  noBl               String?
  namaPBM            String?
  namaMKL            String?
  noSuratJalan       String?
  vehicleNo          String?

  // Dokumen
  imageUrl           String?
  rfidFileUrl        String?
  rfidImported       Boolean          @default(false)
  rfidCount          Int              @default(0)

  // Data timbang agregat
  totalHeadArrived   Int              @default(0)
  grossWeightTotal   Float            @default(0)
  tareWeightTotal    Float            @default(0)
  netWeightTotal     Float            @default(0)
  avgWeightReceived  Float            @default(0)

  // Susut transit
  avgWeightPurchase  Float            @default(0)
  susutKg            Float            @default(0)
  susutPct           Float            @default(0)
  susutAlert         Boolean          @default(false)

  condition          String           @default("GOOD")
  receivedBy         String
  notes              String?
  status             String           @default("PENDING_GRADING")

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  trucks             CattleTruck[]
  rfidTags           RfidTag[]
  cattle             CattleInventory[]

  @@index([purchasingId])
  @@index([status])
  @@index([createdAt])
}

// ─── Truck Timbang ────────────────────────────────────────────────────────────

model CattleTruck {
  id               String        @id @default(cuid())
  arrivalId        String
  arrival          CattleArrival @relation(fields: [arrivalId], references: [id], onDelete: Cascade)
  noTruk           String
  supirTruk        String?
  grossWeight      Float         @default(0)
  tareWeight       Float         @default(0)
  netWeight        Float         @default(0)
  headCount        Int           @default(0)
  avgWeightPerHead Float         @default(0)
  notes            String?
  weighedAt        DateTime      @default(now())

  @@index([arrivalId])
}

// ─── RFID / Eartag ────────────────────────────────────────────────────────────

model RfidTag {
  id         String         @id @default(cuid())
  rfidNo     String         @unique
  eartagNo   String?
  arrivalId  String?
  arrival    CattleArrival? @relation(fields: [arrivalId], references: [id])
  cattleId   String?        @unique
  cattle     CattleInventory? @relation(fields: [cattleId], references: [id])
  scannedAt  DateTime       @default(now())
  importedAt DateTime       @default(now())
  importedBy String?
  status     String         @default("ACTIVE")
  notes      String?

  @@index([rfidNo])
  @@index([arrivalId])
  @@index([status])
}

// ─── Cattle Batch (FIFO Stok Sapi) ───────────────────────────────────────────
//
// Diperbarui dari versi lama:
//   - Ganti poId → purchasingId (konsisten dengan CattlePurchasing)
//   - Tambah field: vendorName, noPO, headReserved, headSold, headDead,
//     avgWeightReceived, avgWeightCurrent, totalWeightCurrent,
//     hppAwalPerEkor, hppKumulatifPerEkor, totalHppKumulatif,
//     priceUSD, exchangeRate, arrivedAt, depletedAt
//   - Hapus: jenisSapi, gender (dipindah ke CattleInventory per ekor)

model CattleBatch {
  id                   String           @id @default(cuid())
  batchNo              String           @unique
  purchasingId         String
  purchasing           CattlePurchasing @relation(fields: [purchasingId], references: [id])
  warehouseId          String
  warehouse            Warehouse        @relation(fields: [warehouseId], references: [id])

  vendorName           String
  noPO                 String

  // Kuantitas ekor
  headInitial          Int              @default(0)
  headRemaining        Int              @default(0)
  headReserved         Int              @default(0)
  headSold             Int              @default(0)
  headDead             Int              @default(0)

  // Bobot agregat
  avgWeightReceived    Float            @default(0)
  avgWeightCurrent     Float            @default(0)
  totalWeightCurrent   Float            @default(0)

  // Finansial & HPP
  hppAwalPerEkor       Float            @default(0)
  hppKumulatifPerEkor  Float            @default(0)
  totalHppKumulatif    Float            @default(0)
  priceUSD             Float            @default(0)
  exchangeRate         Float            @default(0)

  status               String           @default("ACTIVE")

  arrivedAt            DateTime         @default(now())
  depletedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  cattle               CattleInventory[]
  overheads            CattleOverhead[]
  deductions           CattleBatchDeduction[]

  @@index([status])
  @@index([arrivedAt])
  @@index([warehouseId])
  @@index([purchasingId])
}

// ─── Cattle Inventory (Data per Ekor) ────────────────────────────────────────

model CattleInventory {
  id            String         @id @default(cuid())

  // Identifikasi
  rfidNo        String?
  eartagNo      String?        @unique
  internalCode  String?

  arrivalId     String
  arrival       CattleArrival  @relation(fields: [arrivalId], references: [id])

  batchId       String?
  batch         CattleBatch?   @relation(fields: [batchId], references: [id])

  warehouseId   String?
  warehouse     Warehouse?     @relation(fields: [warehouseId], references: [id])

  // Info sapi
  jenisKelamin  String         @default("JANTAN")
  breed         String?
  ageMonths     Int?

  // 4 Jenis Bobot
  weightPurchase Float         @default(0)  // Bobot saat beli (kg)
  weightReceived Float         @default(0)  // Bobot saat tiba di kandang (kg)
  weightGrading  Float         @default(0)  // Bobot setelah grading (kg)
  weightHarvest  Float         @default(0)  // Bobot saat panen/jual (kg)
  weightCurrent  Float         @default(0)  // Bobot terkini (kg)

  // Susut per ekor
  susutKg       Float          @default(0)
  susutPct      Float          @default(0)

  // HPP per ekor
  hppAwal       Float          @default(0)
  hppKumulatif  Float          @default(0)

  status        String         @default("QUARANTINE")

  masukKandangAt  DateTime     @default(now())
  keluarKandangAt DateTime?

  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  rfidTag       RfidTag?
  overheads     CattleOverhead[]

  @@index([arrivalId])
  @@index([batchId])
  @@index([status])
  @@index([rfidNo])
}

// ─── Overhead Harian (HPP Kumulatif Sapi) ────────────────────────────────────

model CattleOverhead {
  id          String           @id @default(cuid())
  batchId     String?
  batch       CattleBatch?     @relation(fields: [batchId], references: [id])
  cattleId    String?
  cattle      CattleInventory? @relation(fields: [cattleId], references: [id])
  warehouseId String?

  // Jenis: PAKAN | TENAGAKERJA | LISTRIK | AIR | KESEHATAN | LAINNYA
  kategori    String
  deskripsi   String

  biayaTotal  Float            @default(0)
  headCount   Int              @default(1)
  biayaPerEkor Float           @default(0)

  periode     DateTime         @default(now())
  dicatatOleh String

  createdAt   DateTime         @default(now())

  @@index([batchId])
  @@index([periode])
  @@index([kategori])
}

// ─── Cattle Batch Deduction (FIFO Out) ───────────────────────────────────────

model CattleBatchDeduction {
  id            String      @id @default(cuid())
  batchId       String
  batch         CattleBatch @relation(fields: [batchId], references: [id])
  referenceId   String?
  referenceType String?     // "SALES" | "TRANSFER" | "DEAD"
  referenceNo   String?
  headDeducted  Int         @default(0)
  avgWeightKg   Float       @default(0)
  hppPerEkor    Float       @default(0)
  totalHpp      Float       @default(0)
  deductedBy    String?
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([batchId])
  @@index([referenceId])
}

// ═══════════════════════════════════════════════════════════════════════════
// OTHER MODELS
// ═══════════════════════════════════════════════════════════════════════════

model staffs {
  id          String   @id
  email       String   @unique
  sn          String?
  firstName   String
  lastName    String
  gender      String
  staffId     String   @unique
  phone       String?
  role        String
  designation String
  image       String?  // URL foto profil staff
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  User        User     @relation(fields: [id], references: [id], onDelete: Cascade)
}

model Task {
  id        String   @id @default(cuid())
  title     String
  time      String
  priority  String
  category  String
  assignee  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model History {
  id          String   @id @default(uuid())
  action      String
  item        String
  category    String
  type        String
  quantity    Float
  unit        String   @default("Unit")
  user        String
  notes       String?
  referenceId String?
  createdAt   DateTime @default(now())
  batchId     String?
}

model Transaction {
  id          String   @id @default(cuid())
  trxNo       String
  category    String
  description String?
  amount      Float
  type        String
  date        DateTime @default(now())
  method      String   @default("CASH")
  createdBy   String
  referenceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

