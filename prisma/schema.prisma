generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Warehouse {
  id          String       @id @default(cuid())
  name        String       @unique
  code        String?      @unique
  address     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  productions Production[]
  receipts    Receipt[]
  sttbs       STTB[]
  stocks      Stock[]
  batches     StockBatch[]
}

model User {
  id        String          @id @default(cuid())
  username  String          @unique
  email     String          @unique
  password  String
  phone     String?
  role      String          @default("Staff")
  createdAt DateTime        @default(now())
  roleData  RolePermission? @relation("UserToRole", fields: [role], references: [roleName])
  staffs    staffs?
}

model RolePermission {
  id          String   @id @default(cuid())
  roleName    String   @unique
  permissions String[]
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("UserToRole")
}

model DeliveryOrder {
  id           String              @id @default(cuid())
  doNo         String              @unique
  expectedDate DateTime?
  notes        String?             @default("")
  requestedBy  String
  status       String              @default("PENDING")
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  title        String?
  items        DeliveryOrderItem[]
}

model DeliveryOrderItem {
  id               String        @id @default(cuid())
  deliveryOrderId  String
  unit             String        @default("Kg")
  estimasiHarga    Float         @default(0)
  notes            String?       @default("")
  createdAt        DateTime      @default(now())
  qtyRequired      Float         @default(0)
  category         String        @default("")
  type             String        @default("STOCKS")
  qtyOrdered       Float         @default(0)
  itemName         String
  updatedAt        DateTime      @updatedAt
  deliveryOrder    DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  purchasingOrders Purchasing[]
}

model Purchasing {
  id                  String             @id @default(cuid())
  noPO                String
  item                String
  category            String
  type                String             @default("STOCKS")
  supplier            String?
  status              PurchaseStatus     @default(PENDING)
  isReceived          Boolean            @default(false)
  requestedBy         String
  approvedBy          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  price               String?
  unit                String             @default("KG")
  qty                 Float              @default(0)
  notes               String?
  deliveryOrderItemId String?
  deliveryOrderItem   DeliveryOrderItem? @relation(fields: [deliveryOrderItemId], references: [id])
  receipts            Receipt[]
  sttb                STTB?
  batches             StockBatch[]
}

model Receipt {
  id           String      @id @default(cuid())
  receiptNo    String      @unique
  purchasingId String
  suratJalan   String
  vehicleNo    String
  receivedQty  Float
  receivedBy   String
  condition    String      @default("GOOD")
  notes        String?
  receivedAt   DateTime    @default(now())
  grossWeight  Float       @default(0)
  netWeight    Float       @default(0)
  tareWeight   Float       @default(0)
  imageUrl     String?
  warehouseId  String?
  refraksi     Float       @default(0)
  purchasing   Purchasing  @relation(fields: [purchasingId], references: [id])
  warehouse    Warehouse?  @relation(fields: [warehouseId], references: [id])
  sttb         STTB?
  batch        StockBatch?
}

model STTB {
  id                   String      @id @default(cuid())
  sttbNo               String      @unique
  receiptId            String      @unique
  purchasingId         String      @unique
  status               String      @default("PENDING_QC")
  qcApprovedBy         String?
  qcApprovedAt         DateTime?
  qcNotes              String?
  supervisorApprovedBy String?
  supervisorApprovedAt DateTime?
  supervisorNotes      String?
  managerApprovedBy    String?
  managerApprovedAt    DateTime?
  managerNotes         String?
  warehouseId          String?
  stockCommitted       Boolean     @default(false)
  stockCommittedAt     DateTime?
  rejectedBy           String?
  rejectedAt           DateTime?
  rejectedNotes        String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  adminApprovedAt      DateTime?
  adminApprovedBy      String?
  adminNotes           String?
  purchasing           Purchasing  @relation(fields: [purchasingId], references: [id])
  receipt              Receipt     @relation(fields: [receiptId], references: [id])
  warehouse            Warehouse?  @relation(fields: [warehouseId], references: [id])
  batch                StockBatch?
}

model Stock {
  id              String    @id @default(cuid())
  name            String
  category        String
  stock           Float
  unit            String
  type            String
  price           String?
  status          String?
  lastPurchasedId String?
  updatedAt       DateTime  @updatedAt
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([name, warehouseId])
}

model StockBatch {
  id                        String                      @id @default(cuid())
  batchNo                   String                      @unique
  itemName                  String
  warehouseId               String
  purchasingId              String?
  receiptId                 String?                     @unique
  sttbId                    String?                     @unique
  supplierName              String?
  noPO                      String?
  suratJalan                String?
  qtyInitial                Float
  qtyRemaining              Float
  reservedQty               Float                       @default(0)
  unit                      String                      @default("KG")
  category                  String                      @default("General")
  type                      String                      @default("STOCKS")
  price                     String?
  condition                 String?                     @default("GOOD")
  notes                     String?
  status                    String                      @default("ACTIVE")
  receivedAt                DateTime                    @default(now())
  depletedAt                DateTime?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  productionId              String?
  deductions                BatchDeduction[]
  allocations               ProductionBatchAllocation[]
  production                Production?                 @relation("ProductionOutputBatch", fields: [productionId], references: [id])
  purchasing                Purchasing?                 @relation(fields: [purchasingId], references: [id])
  receipt                   Receipt?                    @relation(fields: [receiptId], references: [id])
  sttb                      STTB?                       @relation(fields: [sttbId], references: [id])
  warehouse                 Warehouse                   @relation(fields: [warehouseId], references: [id])

  @@index([itemName, warehouseId, status])
  @@index([receivedAt])
  @@index([status])
  @@index([reservedQty])
}

model BatchDeduction {
  id            String     @id @default(cuid())
  batchId       String
  referenceId   String?
  referenceType String?
  referenceNo   String?
  qtyDeducted   Float
  unit          String     @default("KG")
  deductedBy    String?
  notes         String?
  createdAt     DateTime   @default(now())
  batch         StockBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([referenceId])
  @@index([createdAt])
}

model Production {
  id                   String                @id @default(cuid())
  noBatch              String                @unique
  productName          String
  targetQty            Float
  actualQty            Float?
  status               ProductionStatus      @default(PENDING_QC_PROD)
  totalCost            Float                 @default(0)
  unitCost             Float                 @default(0)
  startDate            DateTime              @default(now())
  endDate              DateTime?
  createdBy            String
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  adminApprovedAt      DateTime?
  adminApprovedBy      String?
  adminNotes           String?
  hpp                  Float                 @default(0)
  lossWarning          Boolean               @default(false)
  managerApprovedAt    DateTime?
  managerApprovedBy    String?
  managerNotes         String?
  qcApprovedAt         DateTime?
  qcApprovedBy         String?
  qcNotes              String?
  rejectedAt           DateTime?
  rejectedBy           String?
  rejectedNotes        String?
  rendemen             Float?
  supervisorApprovedAt DateTime?
  supervisorApprovedBy String?
  supervisorNotes      String?
  targetUnit           String                @default("UNIT")
  warehouseId          String?
  // ─── Soft-reserve fields ─────────────────────────────────────────────────
  isReserved           Boolean               @default(false)
  reservedAt           DateTime?
  reservedBy           String?
  // ─────────────────────────────────────────────────────────────────────────
  warehouse            Warehouse?            @relation(fields: [warehouseId], references: [id])
  components           ProductionComponent[]
  outputBatches        StockBatch[]          @relation("ProductionOutputBatch")

  @@index([isReserved])
}

model ProductionComponent {
  id                        String                      @id @default(cuid())
  productionId              String
  itemName                  String
  qtyNeeded                 Float
  unit                      String                      @default("KG")
  createdAt                 DateTime                    @default(now())
  batchAllocation           String?                     @default("[]")
  stockAvailable            Float                       @default(0)
  totalPrice                Float                       @default(0)
  unitPrice                 Float                       @default(0)
  warehouseId               String?
  // ─── Soft-reserve field ──────────────────────────────────────────────────
  reservedQty               Float                       @default(0)
  // ─────────────────────────────────────────────────────────────────────────
  allocations               ProductionBatchAllocation[]
  production                Production                  @relation(fields: [productionId], references: [id], onDelete: Cascade)
}

model ProductionBatchAllocation {
  id                    String              @id @default(cuid())
  productionComponentId String
  batchId               String
  qtyAllocated          Float               @default(0)
  isReserved            Boolean             @default(false)
  isDeducted            Boolean             @default(false)
  createdAt             DateTime            @default(now())
  batch                 StockBatch          @relation(fields: [batchId], references: [id], onUpdate: NoAction)
  productionComponent   ProductionComponent @relation(fields: [productionComponentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([batchId])
  @@index([productionComponentId])
  @@index([isReserved])
}

model Task {
  id        String   @id @default(cuid())
  title     String
  time      String
  priority  String
  category  String
  assignee  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model History {
  id          String   @id @default(uuid())
  action      String
  item        String
  category    String
  type        String
  quantity    Float
  unit        String   @default("Unit")
  user        String
  notes       String?
  referenceId String?
  createdAt   DateTime @default(now())
  batchId     String?
}

// ─── PENJUALAN ────────────────────────────────────────────────────────────────
model Penjualan {
  id                   String          @id @default(cuid())
  invoiceId            String          @unique
  totalAmount          Float           @default(0)
  status               String          @default("PENDING_SALES")
  customerId           String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  createdBy            String?
  deliveryAddress      String?
  discount             Float           @default(0)
  discountPct          Float           @default(0)
  dueDate              DateTime?
  notes                String?
  paidAt               DateTime?
  paymentMethod        String?         @default("CASH")
  quotationId          String?
  salesNotes           String?
  shippingCost         Float           @default(0)
  subtotal             Float           @default(0)
  taxAmount            Float           @default(0)
  taxPct               Float           @default(0)
  saleType             String          @default("REGULAR")
  
  // Stage 1 — Sales
  salesApprovedBy      String?
  salesApprovedAt      DateTime?
  salesNotes2          String?         // notes dari Sales approver (beda dari salesNotes input)
  
  // Stage 2 — Admin
  adminApprovedBy      String?
  adminApprovedAt      DateTime?
  adminNotes2          String?
  
  // Stage 3 — Supervisor
  supervisorApprovedBy String?
  supervisorApprovedAt DateTime?
  supervisorNotes      String?
  
  // Stage 4 — Manager (Final)
  managerApprovedBy    String?
  managerApprovedAt    DateTime?
  managerNotes         String?
  
  // Reject
  rejectedBy           String?
  rejectedAt           DateTime?
  rejectedNotes        String?
  
  // FIFO tracking
  isStockDeducted      Boolean         @default(false)  // true setelah Manager approve / Direct sale
  
  customer             Contact?        @relation(fields: [customerId], references: [id])
  quotation            SalesQuotation? @relation("QuotationToSale", fields: [quotationId], references: [id])
  items                PenjualanItem[]
  
  @@index([saleType])
  @@index([status])
  @@index([isStockDeducted])
}

model PenjualanItem {
  id               String    @id @default(cuid())
  productName      String
  quantity         Float
  unit             String?   @default("Unit")
  price            Float
  penjualanId      String
  discount         Float     @default(0)
  notes            String?
  subtotal         Float     @default(0)
  
  // ─── SALES UPGRADE: FIFO & Cost Fields ───────────────────────────────
  batchAllocation  String?   @default("[]")
  warehouseId      String?   // gudang sumber bahan
  unitCost         Float     @default(0)   // HPP per unit (dari batch)
  totalCost        Float     @default(0)   // HPP total item
  margin           Float     @default(0)   // margin = price - unitCost (per unit)
  
  penjualan        Penjualan @relation(fields: [penjualanId], references: [id], onDelete: Cascade)
}

model SalesQuotation {
  id          String               @id @default(cuid())
  quotationNo String               @unique
  customerId  String?
  status      String               @default("DRAFT")
  validUntil  DateTime?
  notes       String?
  subtotal    Float                @default(0)
  discountPct Float                @default(0)
  discount    Float                @default(0)
  taxPct      Float                @default(0)
  taxAmount   Float                @default(0)
  totalAmount Float                @default(0)
  createdBy   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  salesOrders Penjualan[]          @relation("QuotationToSale")
  customer    Contact?             @relation(fields: [customerId], references: [id])
  items       SalesQuotationItem[]
}

model SalesQuotationItem {
  id          String         @id @default(cuid())
  quotationId String
  productName String
  quantity    Float
  unit        String         @default("Unit")
  price       Float
  discount    Float          @default(0)
  subtotal    Float          @default(0)
  notes       String?
  quotation   SalesQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Contact {
  id          String           @id @default(cuid())
  name        String
  type        ContactType      @default(CUSTOMER)
  email       String?          @unique
  phone       String?
  address     String?
  createdAt   DateTime         @default(now())
  companyName String?
  nik         String?          @unique
  penjualan   Penjualan[]
  quotations  SalesQuotation[]
}

model staffs {
  id          String   @id
  email       String   @unique
  sn          String?
  firstName   String
  lastName    String
  gender      String
  staffId     String   @unique
  phone       String?
  role        String
  designation String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [id], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(cuid())
  trxNo       String
  category    String
  description String?
  amount      Float
  type        String
  date        DateTime @default(now())
  method      String   @default("CASH")
  createdBy   String
  referenceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PurchaseStatus {
  PENDING
  APPROVED
  REJECTED
  RECEIVED
}

enum ProductionStatus {
  PENDING_QC_PROD
  PENDING_ADMIN
  PENDING_SUPERVISOR
  PENDING_MANAGER
  COMPLETED
  CANCELLED
}

enum PenjualanStatus {
  PENDING_SALES
  PENDING_ADMIN
  PENDING_SUPERVISOR
  PENDING_MANAGER
  COMPLETED
  CANCELLED
  REJECTED
}

enum ContactType {
  CUSTOMER
  SUPPLIER
}